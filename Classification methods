class note:
    """A CLass to represent a preset note with a fixed frequency
    Args:
        private frequency (float): The frequency of the note in Hz
    Methods:
        __init__(self, frequency): Initializes the note with the given frequency
        GetFrequency(self): Returns the frequency of the note

    """
    def __init__(self, frequency):
        self.__frequency = abs(frequency)
    def GetFrequency(self):
        return self.__frequency


class Signal(note):
    """A Class to represent a real signal inherted from the note class with a modifiable frequency
    Args:
        public frequency (float): The frequency of the signal in Hz
    Methods:
        __init__(self, frequency): Initializes the signal with the given frequency
        GetFrequency(self): Returns the frequency of the signal
        SetFrequency(self, frequency): Sets the frequency of the signal to the given value
    """
    def __init__(self, frequency):
        super().__init__(frequency)
        self.frequency = abs(frequency)
    def SetFrequency(self, frequency):
        self.frequency = frequency


class scale:
    """A Class to represent a musical scale with a list of notes
    Args:
        notes (list): A list of note objects representing the notes in the scale
        keys (list): A list of keys as characters representing the notes in the scale
    Methods:
        __init__(self, notes): Initializes the scale with the given list of notes
        GetNotes(self): Returns the list of notes in the scale
        GetKeys(self): Returns the list of keys representing the notes in the scale
    """
    def __init__(self,notes,keys):
        self.notes = notes
        self.keys = keys
    def GetNotes(self):
        return self.notes
    def GetKeys(self):
        return self.keys
class note_analyser:
    """A Class to analyze a signal and determine the closest note in a given scale
    args:
        signal_in (Signal): The signal to be analyzed
        tune (scale): The scale to be used for tuning
        index (int): The index of the closest note in the scale
        error (float): A temporary value used for storing the difference between frequencies
    Methods:
        __init__(self, signal_in, tune): Initializes the note analyser with the given signal and scale
        Find_String(self): Finds the closest note in the scale to the signal and returns its index
        Find_Error(self): Finds the error between the signal frequency and the closest note frequency and returns it
    """
    def __init__(self, signal_in ,tune):
        self.signal_in = signal_in
        self.tune=tune
        self.index = self.Find_String(self)
        self.error =0

    
    def Find_String(self):
        """Finds the closest note in the scale to the signal and returns its index
        Returns:
            int: The index of the closest note in the scale
        """
        self.error = abs(signal_in.GetFrequency() - tune.GetNotes()[0].GetFrequency())
        self.index=0
        for i in range(len(self.tune.GetNotes())):
            
            if self.error > abs(signal_in.GetFrequency() - tune.GetNotes()[i].GetFrequency()):
                self.error = abs(signal_in.GetFrequency() - tune.GetNotes()[i].GetFrequency())
                self.index = i
        return index

    def Find_Error(self):
        """Finds the error between the signal frequency and the closest note frequency and returns it
        Returns:
            float: The error between the signal frequency and the closest note frequency
            character: A character indicating whether the signal is flat (b), sharp (#), or in tune ( )
        """
        self.error = self.signal_in.GetFrequency() - self.tune.GetNotes()[self.index].GetFrequency()
        if self.error < 0:
            return self.error, 'b'
        elif self.error > 0:
            return self.error, '#'
        else:
            return self.error, ' '
